datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Driver {
  id            Int            @id @default(autoincrement())
  driverId      String         @unique
  name          String
  licenseNumber String         @unique
  phone         String
  email         String         @unique
  records       DriverRecord[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model DriverRecord {
  id                    Int             @id @default(autoincrement())
  driverId              String
  driver                Driver          @relation(fields: [driverId], references: [driverId], onDelete: Cascade)
  driverName            String
  month                 String
  tripsCompleted        Int
  onTimeTrips           Int
  lateTrips             Int
  punctualityPercentage Float
  customerRating        Float
  complaints            Int
  baseSalary            Int
  incentiveAmount       Int
  finalPayout           Int
  status                String          @default("Pending")
  payments              PaymentRecord[]
  auditLogs             AuditLog[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  // Enforces that a driver can only have one incentive record per month
  @@unique([driverId, month])
  @@index([driverId])
  @@index([month])
}

model PaymentRecord {
  id             Int          @id @default(autoincrement())
  recordId       Int
  record         DriverRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  amount         Int
  paymentDate    DateTime     @default(now())
  paymentMethod  String       @default("Bank Transfer")
  transactionId  String       @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([recordId])
}

model Staff {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  role      String   @default("Operator")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  email     String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id          Int           @id @default(autoincrement())
  action      String
  details     String
  performedBy String
  recordId    Int?
  record      DriverRecord? @relation(fields: [recordId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())

  @@index([recordId])
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   @default("Operator")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LoginSession {
  id         Int      @id @default(autoincrement())
  userEmail  String
  role       String
  loginTime  DateTime @default(now())
  status     String   // "SUCCESS" or "FAILED"
  ipAddress  String?
}

model SystemConfig {
  id                Int      @id @default(autoincrement())
  tierName          String   @unique // e.g. "Tier 1", "Tier 2", "Tier 3"
  requiredTrips     Int
  requiredRating    Float
  allowedComplaints Int
  payoutAmount      Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}


